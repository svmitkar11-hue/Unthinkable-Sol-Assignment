# ============================================================
# Society Maintenance Tracker — environment configuration
# Copy to .env and fill in. Used by docker-compose and backend.
# ============================================================

# --- Database (backend) ---
DB_URL=jdbc:postgresql://localhost:5432/society
DB_USERNAME=society
DB_PASSWORD=society

# --- Auth ---
# Must be at least 32 bytes for HS384 signing.
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes-long
JWT_EXPIRATION_MS=86400000

# --- Seeded admin account (created on first boot) ---
ADMIN_EMAIL=admin@society.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=Society Admin

# --- Seed demo resident + sample complaints/notice ---
SEED_DEMO=true

# --- CORS (frontend origin) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Overdue detection ---
OVERDUE_THRESHOLD_DAYS=7

# --- Signup OTP (printed to backend terminal; also emailed if MAIL_ENABLED=true) ---
OTP_TTL_MINUTES=10

# --- Email (Gmail SMTP). Create an App Password: https://myaccount.google.com/apppasswords ---
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=youraddress@gmail.com

# --- Cloudinary (photo uploads). Dashboard: https://cloudinary.com/console ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:8080/api
